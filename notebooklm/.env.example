# Google auth cookie JSON exported after running `notebooklm login`
# Run: notebooklm login --save-json > auth.json
# Then set this to the contents of auth.json
NOTEBOOKLM_AUTH_JSON=

# Optional: path to a persistent Chromium profile directory
# Reuse avoids repeated logins across sessions
NOTEBOOKLM_PROFILE=~/.notebooklm-profile
