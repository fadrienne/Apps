# Copy this file to .env and fill in your values.
# Run `notebooklm login` first to authenticate interactively,
# OR set NOTEBOOKLM_AUTH_JSON for headless / CI environments.

# For CI/CD: paste the JSON output of `notebooklm auth export`
# NOTEBOOKLM_AUTH_JSON={"token": "...", ...}

# Switch between named auth profiles
# NOTEBOOKLM_PROFILE=default
